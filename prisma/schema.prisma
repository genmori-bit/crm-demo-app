  objectType   String
  fileName     String
  status       String    @default("pending")
  totalRows    Int       @default(0)
  importedRows Int       @default(0)
  errorRows    Int       @default(0)
  errors       Json      @default("[]")
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?

  @@index([objectType])
  @@index([status])
  @@index([createdAt])
}

model ExportJob {
  id          String    @id @default(cuid())
  objectType  String
  filters     Json      @default("{}")
  status      String    @default("pending")
  fileName    String?
  rowCount    Int       @default(0)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([objectType])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  objectType String
  objectId   String
  action     String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([objectType, objectId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model DataTag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#0176d3")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies CompanyTag[]
  deals     DealTag[]
}

model CompanyTag {
  companyId String
  tagId     String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag     DataTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([companyId, tagId])
}

model DealTag {
  dealId    String
  tagId     String
  createdAt DateTime @default(now())

  deal Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tag  DataTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([dealId, tagId])
}

// ===================== Marketing Automation =====================

model Prospect {
  id             String    @id @default(cuid())
  email          String    @unique
  firstName      String?
  lastName       String?
  companyName    String?
  jobTitle       String?
  phone          String?
  website        String?
  industry       String?
  employeeSize   String?
  annualRevenue  Float?
  country        String?
  state          String?
  city           String?
  postalCode     String?
  source         String?
  score          Int       @default(0)
  grade          String    @default("D")
  status         String    @default("active")
  doNotEmail     Boolean   @default(false)
  optedOut       Boolean   @default(false)
  optedOutAt     DateTime?
  emailBounced   Boolean   @default(false)
  emailBouncedAt DateTime?
  spamComplaint  Boolean   @default(false)
  isConverted    Boolean   @default(false)
  convertedAt    DateTime?
  crmContactId   String?
  companyId      String?
  assignedUserId String?
  lastActivityAt DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  deletedAt      DateTime?

  company            Company?                  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  crmContact         Contact?
  crmLead            Lead?
  activities         ProspectActivity[]
  listMemberships    MarketingListMembership[]
  emailRecipients    EmailRecipient[]
  formSubmissions    FormSubmission[]
  visits             Visit[]
  programEnrollments ProgramEnrollment[]
  campaignMembers    CampaignMember[]

  @@index([email])
  @@index([status])
  @@index([score])
  @@index([assignedUserId])
  @@index([companyId])
  @@index([deletedAt])
  @@index([createdAt])
}

model ProspectActivity {
  id         String   @id @default(cuid())
  prospectId String
  type       String
  description String
  metadata   Json     @default("{}")
  score      Int      @default(0)
  createdAt  DateTime @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@index([type])
  @@index([createdAt])
}

model Visitor {
  id          String    @id @default(cuid())
  visitorUid  String    @unique
  prospectId  String?
  ipAddress   String?
  userAgent   String?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  pageViews   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  visits Visit[]

  @@index([prospectId])
  @@index([visitorUid])
  @@index([lastSeenAt])
}

model Visit {
  id         String    @id @default(cuid())
  visitorId  String
  prospectId String?
  startedAt  DateTime  @default(now())
  endedAt    DateTime?
  duration   Int?
  pageCount  Int       @default(1)
  referrer   String?
  campaign   String?
  medium     String?
  source     String?
  createdAt  DateTime  @default(now())

  visitor   Visitor   @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  prospect  Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  pageViews PageView[]

  @@index([visitorId])
  @@index([prospectId])
  @@index([startedAt])
}

model PageView {
  id       String   @id @default(cuid())
  visitId  String
  url      String
  title    String?
  duration Int?
  viewedAt DateTime @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@index([url])
  @@index([viewedAt])
}

model MarketingList {
  id          String    @id @default(cuid())
  name        String
  description String?
  type        String    @default("static")
  rules       Json      @default("[]")
  isPublic    Boolean   @default(false)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  memberships     MarketingListMembership[]
  leadMemberships LeadListMembership[]
  emailSends      MarketingEmail[]

  @@index([type])
  @@index([deletedAt])
}

model MarketingListMembership {
  listId     String
  prospectId String
  addedAt    DateTime @default(now())
  addedBy    String?

  list     MarketingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  prospect Prospect      @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@id([listId, prospectId])
  @@index([listId])
  @@index([prospectId])
}

model EmailTemplate {
  id          String    @id @default(cuid())
  name        String
  subject     String
  previewText String?
  bodyHtml    String
  bodyText    String?
  fromName    String?
  fromEmail   String?
  replyTo     String?
  type        String    @default("regular")
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  emails MarketingEmail[]

  @@index([type])
  @@index([deletedAt])
}

model MarketingEmail {
  id           String    @id @default(cuid())
  name         String
  subject      String
  templateId   String?
  listId       String?
  campaignId   String?
  fromName     String
  fromEmail    String
  replyTo      String?
  bodyHtml     String
  bodyText     String?
  status       String    @default("draft")
  scheduledAt  DateTime?
  sentAt       DateTime?
  totalSent    Int       @default(0)
  totalOpened  Int       @default(0)
  totalClicked Int       @default(0)
  totalBounced Int       @default(0)
  totalOptOut  Int       @default(0)
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  template   EmailTemplate?  @relation(fields: [templateId], references: [id])
  list       MarketingList?  @relation(fields: [listId], references: [id])
  campaign   Campaign?       @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  recipients     EmailRecipient[]
  leadRecipients LeadEmailRecipient[]

  @@index([status])
  @@index([scheduledAt])
  @@index([campaignId])
  @@index([deletedAt])
}

model EmailRecipient {
  id         String    @id @default(cuid())
  emailId    String
  prospectId String
  status     String    @default("pending")
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  bouncedAt  DateTime?
  optedOutAt DateTime?
  metadata   Json      @default("{}")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  email    MarketingEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)
  prospect Prospect       @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([prospectId])
  @@index([status])
}

model MarketingForm {
  id          String    @id @default(cuid())
  name        String
  description String?
  fields      Json      @default("[]")
  style       Json      @default("{}")
  thankYouMsg String?
  redirectUrl String?
  isActive    Boolean   @default(true)
  campaignId  String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaign         Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  submissions      FormSubmission[]
  leadSubmissions  LeadFormSubmission[]
  handlers         FormHandler[]

  @@index([isActive])
  @@index([campaignId])
  @@index([deletedAt])
}

model FormSubmission {
  id          String   @id @default(cuid())
  formId      String
  prospectId  String?
  data        Json     @default("{}")
  ipAddress   String?
  userAgent   String?
  pageUrl     String?
  submittedAt DateTime @default(now())

  form     MarketingForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  prospect Prospect?     @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  @@index([formId])
  @@index([prospectId])
  @@index([submittedAt])
}

model FormHandler {
  id          String    @id @default(cuid())
  formId      String
  name        String
  successUrl  String?
  errorUrl    String?
  isActive    Boolean   @default(true)
  kbaiEnabled Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  form MarketingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}

model LandingPage {
  id          String    @id @default(cuid())
  name        String
  title       String
  slug        String    @unique
  description String?
  bodyHtml    String    @default("")
  metaTitle   String?
  metaDesc    String?
  status      String    @default("draft")
  publishedAt DateTime?
  views       Int       @default(0)
  campaignId  String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaign Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([slug])
  @@index([campaignId])
  @@index([deletedAt])
}

model EngagementProgram {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("draft")
  startDate   DateTime?
  endDate     DateTime?
  campaignId  String?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  campaign         Campaign?              @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  nodes            EngagementProgramNode[]
  enrollments      ProgramEnrollment[]
  leadEnrollments  LeadProgramEnrollment[]

  @@index([status])
  @@index([campaignId])
  @@index([deletedAt])
}

model EngagementProgramNode {
  id        String @id @default(cuid())
  programId String
  type      String
  label     String
  config    Json   @default("{}")
  positionX Float  @default(0)
  positionY Float  @default(0)
  nextNodeId String?
  yesNodeId  String?
  noNodeId   String?

  program EngagementProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

model ProgramEnrollment {
  id          String    @id @default(cuid())
  programId   String
  prospectId  String
  status      String    @default("active")
  currentNode String?
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  program  EngagementProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  prospect Prospect          @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([programId, prospectId])
  @@index([programId])
  @@index([prospectId])
  @@index([status])
}

model AutomationRule {
  id          String    @id @default(cuid())
  name        String
  description String?
  triggerType String
  triggerConf Json      @default("{}")
  conditions  Json      @default("[]")
  actions     Json      @default("[]")
  isActive    Boolean   @default(false)
  runCount    Int       @default(0)
  lastRunAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([triggerType])
  @@index([isActive])
  @@index([deletedAt])
}

model ScoringRule {
  id          String   @id @default(cuid())
  name        String
  category    String   @default("behavior")
  triggerType String
  conditions  Json     @default("[]")
  scoreChange Int
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([category])
  @@index([isActive])
}

model GradingProfile {
  id          String   @id @default(cuid())
  name        String
  description String?
  criteria    Json     @default("[]")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

// ===================== Custom Object Metadata =====================

model ObjectDefinition {
  id                 String    @id @default(cuid())
  apiName            String    @unique
  label              String
  pluralLabel        String
  description        String?
  objectType         String    @default("CUSTOM")
  category           String    @default("CUSTOM")
  icon               String?
  isActive           Boolean   @default(true)
  isSearchable       Boolean   @default(true)
  isReportable       Boolean   @default(true)
  isAuditable        Boolean   @default(true)
  enableActivities   Boolean   @default(true)
  enableNotes        Boolean   @default(true)
  enableFiles        Boolean   @default(false)
  enableSharing      Boolean   @default(false)
  enableHistory      Boolean   @default(true)
  enableCustomFields Boolean   @default(true)
  nameFieldType      String    @default("TEXT")
  nameFieldLabel     String    @default("名前")
  nameFieldApiName   String    @default("Name")
  autoNumberFormat   String?
  ownerId            String?
  createdById        String?
  updatedById        String?
  createdAt          DateTime  @default(now())
  updatedAt          DateTime  @updatedAt
  deletedAt          DateTime?

  fields         FieldDefinition[]
  records        CustomObjectRecord[]
  layouts        PageLayoutDefinition[]
  listViews      ListViewDefinition[]
  recordTypes    RecordTypeDefinition[]
  validationRules ValidationRuleDefinition[]
  customTabs     CustomTabDefinition[]

  @@index([apiName])
  @@index([objectType])
  @@index([isActive])
  @@index([deletedAt])
}

model FieldDefinition {
  id                     String    @id @default(cuid())
  objectDefinitionId     String
  apiName                String
  label                  String
  description            String?
  fieldType              String    @default("TEXT")
  isRequired             Boolean   @default(false)
  isUnique               Boolean   @default(false)
  isIndexed              Boolean   @default(false)
  isReadonly             Boolean   @default(false)
  isSystem               Boolean   @default(false)
  defaultValue           String?
  helpText               String?
  placeholder            String?
  options                Json?
  referenceObjectApiName String?
  referenceLabelField    String?
  relationshipName       String?
  precision              Int?
  scale                  Int?
  maxLength              Int?
  formulaExpression      String?
  sortOrder              Int       @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  deletedAt              DateTime?

  objectDefinition ObjectDefinition         @relation(fields: [objectDefinitionId], references: [id], onDelete: Cascade)
  lookupValues     CustomObjectLookupValue[]

  @@unique([objectDefinitionId, apiName])
  @@index([objectDefinitionId])
  @@index([fieldType])
  @@index([deletedAt])
}

model CustomObjectRecord {
  id               String    @id @default(cuid())
  objectDefinitionId String
  name             String
  values           Json      @default("{}")
  ownerId          String?
  createdById      String?
  updatedById      String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  objectDefinition ObjectDefinition          @relation(fields: [objectDefinitionId], references: [id], onDelete: Cascade)
  lookupValues     CustomObjectLookupValue[]

  @@index([objectDefinitionId])
  @@index([name])
  @@index([ownerId])
  @@index([createdAt])
  @@index([deletedAt])
}

model CustomObjectLookupValue {
  id                  String   @id @default(cuid())
  recordId            String
  fieldDefinitionId   String
  targetObjectApiName String
  targetRecordId      String
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  record          CustomObjectRecord @relation(fields: [recordId], references: [id], onDelete: Cascade)
  fieldDefinition FieldDefinition    @relation(fields: [fieldDefinitionId], references: [id], onDelete: Cascade)

  @@index([recordId])
  @@index([fieldDefinitionId])
  @@index([targetObjectApiName])
  @@index([targetRecordId])
}

model PageLayoutDefinition {
  id               String   @id @default(cuid())
  objectDefinitionId String
  name             String
  description      String?
  layout           Json     @default("{}")
  isDefault        Boolean  @default(false)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  objectDefinition ObjectDefinition @relation(fields: [objectDefinitionId], references: [id], onDelete: Cascade)

  @@index([objectDefinitionId])
}

model ListViewDefinition {
  id               String   @id @default(cuid())
  objectDefinitionId String
  name             String
  visibility       String   @default("PRIVATE")
  columns          Json     @default("[]")
  filters          Json     @default("[]")
  sort             Json     @default("{}")
  ownerId          String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  objectDefinition ObjectDefinition @relation(fields: [objectDefinitionId], references: [id], onDelete: Cascade)

  @@index([objectDefinitionId])
  @@index([ownerId])
}

model RecordTypeDefinition {
  id               String   @id @default(cuid())
  objectDefinitionId String
  name             String
  label            String
  description      String?
  isActive         Boolean  @default(true)
  picklistValues   Json?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  objectDefinition ObjectDefinition @relation(fields: [objectDefinitionId], references: [id], onDelete: Cascade)

  @@index([objectDefinitionId])
}

model ValidationRuleDefinition {
  id               String   @id @default(cuid())
  objectDefinitionId String
  name             String
  description      String?
  expression       String
  errorMessage     String
  isActive         Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  objectDefinition ObjectDefinition @relation(fields: [objectDefinitionId], references: [id], onDelete: Cascade)

  @@index([objectDefinitionId])
}

model CustomTabDefinition {
  id               String   @id @default(cuid())
  objectDefinitionId String
  appId            String
  label            String
  icon             String?
  sortOrder        Int      @default(0)
  isVisible        Boolean  @default(true)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  objectDefinition ObjectDefinition @relation(fields: [objectDefinitionId], references: [id], onDelete: Cascade)

  @@index([objectDefinitionId])
  @@index([appId])
}

// ===================== Custom Objects (Seed Examples) =====================

model Subscription {
  id            String    @id @default(cuid())
  companyId     String?
  contractId    String?
  productId     String?
  startDate     DateTime?
  renewalDate   DateTime?
  arr           Float?
  status        String    @default("有効")
  customFields  Json      @default("{}")
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  company  Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contract Contract? @relation(fields: [contractId], references: [id], onDelete: SetNull)
  product  Product?  @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([status])
  @@index([renewalDate])
  @@index([deletedAt])
}
