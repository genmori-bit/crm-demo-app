generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  password      String
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model Company {
  id           String    @id @default(cuid())
  companyName  String
  website      String?
  industry     String?
  employeeSize String?
  status       String    @default("prospect")
  ownerName    String?
  memo         String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  contacts   Contact[]
  deals      Deal[]
  activities Activity[]
  tasks      Task[]
}

model Contact {
  id         String   @id @default(cuid())
  companyId  String
  fullName   String
  email      String?
  phone      String?
  department String?
  title      String?
  isPrimary  Boolean  @default(false)
  memo       String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deals      Deal[]
  activities Activity[]
}

model Deal {
  id               String    @id @default(cuid())
  companyId        String
  contactId        String?
  dealName         String
  stage            String    @default("lead")
  amount           Float     @default(0)
  probability      Int       @default(0)
  expectedCloseDate DateTime?
  nextAction       String?
  memo             String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  activities Activity[]
  tasks      Task[]
}

model Activity {
  id           String   @id @default(cuid())
  companyId    String?
  contactId    String?
  dealId       String?
  type         String   @default("note")
  subject      String
  body         String?
  activityDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company  Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal     Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
}

model Task {
  id          String    @id @default(cuid())
  companyId   String?
  dealId      String?
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("medium")
  status      String    @default("todo")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
}
