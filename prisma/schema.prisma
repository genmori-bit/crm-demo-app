generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  passwordHash         String
  role                 String    @default("SALES")
  status               String    @default("ACTIVE") // PENDING, ACTIVE, DISABLED, LOCKED
  profileId            String?
  department           String?
  title                String?
  phone                String?
  timezone             String    @default("Asia/Tokyo")
  locale               String    @default("ja")
  defaultAppId         String?
  forcePasswordChange  Boolean   @default(false)
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  passwordChangedAt    DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  profile                Profile?                  @relation(fields: [profileId], references: [id], onDelete: SetNull)
  auditLogs              AuditLog[]
  reports                Report[]
  dashboards             Dashboard[]
  permissionSetAssignments PermissionSetAssignment[]
  appAccess              UserAppAccess[]
  teamMemberships        TeamMember[]
  loginHistory           LoginHistory[]
  sentInvitations        UserInvitation[]          @relation("InvitedBy")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Role?  @relation("RoleHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Role[] @relation("RoleHierarchy")

  @@index([parentId])
}

model Profile {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model PermissionSet {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  permissions Json     @default("{}")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments PermissionSetAssignment[]
}

model PermissionSetAssignment {
  id              String   @id @default(cuid())
  userId          String
  permissionSetId String
  assignedAt      DateTime @default(now())
  assignedById    String?

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionSet PermissionSet @relation(fields: [permissionSetId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionSetId])
  @@index([userId])
  @@index([permissionSetId])
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members TeamMember[]
}

model TeamMember {
  teamId   String
  userId   String
  role     String   @default("member") // member, lead
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
}

model UserAppAccess {
  userId    String
  appId     String
  grantedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, appId])
  @@index([userId])
}

model SecuritySettings {
  id                   String   @id @default("singleton")
  minPasswordLength    Int      @default(8)
  requireUppercase     Boolean  @default(true)
  requireNumbers       Boolean  @default(true)
  requireSymbols       Boolean  @default(false)
  passwordExpiryDays   Int      @default(0)
  maxLoginAttempts     Int      @default(5)
  lockoutDurationMins  Int      @default(30)
  sessionTimeoutMins   Int      @default(480)
  mfaRequired          Boolean  @default(false)
  ipWhitelist          Json     @default("[]")
  updatedAt            DateTime @updatedAt
}

model OrgSettings {
  id           String   @id @default("singleton")
  orgName      String   @default("My Organization")
  orgTimezone  String   @default("Asia/Tokyo")
  orgLocale    String   @default("ja")
  fiscalMonth  Int      @default(4)
  dateFormat   String   @default("YYYY/MM/DD")
  currency     String   @default("JPY")
  updatedAt    DateTime @updatedAt
}

model UserInvitation {
  id          String    @id @default(cuid())
  email       String
  name        String?
  role        String    @default("SALES")
  profileId   String?
  token       String    @unique
  invitedById String?
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  invitedBy User? @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([email])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  email     String
  token     String   @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime @default(now())

  @@index([token])
  @@index([email])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  status    String   @default("success") // success, failed, locked
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

model Company {
  id            String    @id @default(cuid())
  companyName   String
  website       String?
  industry      String?
  employeeSize  String?
  status        String    @default("prospect")
  ownerName     String?
  phone         String?
  address       String?
  memo          String?
  annualRevenue Float?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  contacts   Contact[]
  deals      Deal[]
  activities Activity[]
  tasks      Task[]
  tags       CompanyTag[]

  @@index([status])
  @@index([deletedAt])
  @@index([companyName])
}

model Contact {
  id        String    @id @default(cuid())
  companyId String
  fullName  String
  email     String?
  phone     String?
  department String?
  title     String?
  isPrimary Boolean   @default(false)
  memo      String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime?

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  deals      Deal[]
  activities Activity[]

  @@index([companyId])
  @@index([email])
  @@index([deletedAt])
}

model Deal {
  id                String    @id @default(cuid())
  companyId         String
  contactId         String?
  dealName          String
  stage             String    @default("lead")
  amount            Float     @default(0)
  probability       Int       @default(0)
  expectedCloseDate DateTime?
  nextAction        String?
  memo              String?
  lostReason        String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  company    Company    @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact    Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  activities Activity[]
  tasks      Task[]
  tags       DealTag[]

  @@index([companyId])
  @@index([stage])
  @@index([expectedCloseDate])
  @@index([deletedAt])
}

model Activity {
  id           String   @id @default(cuid())
  companyId    String?
  contactId    String?
  dealId       String?
  createdById  String?
  type         String   @default("note")
  subject      String
  body         String?
  activityDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([companyId])
  @@index([dealId])
  @@index([activityDate])
}

model Task {
  id          String    @id @default(cuid())
  companyId   String?
  dealId      String?
  assigneeId  String?
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("medium")
  status      String    @default("todo")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dueDate])
  @@index([dealId])
}

model Report {
  id          String    @id @default(cuid())
  name        String
  description String?
  objectType  String
  columns     Json
  filters     Json      @default("[]")
  sortField   String?
  sortDir     String    @default("desc")
  groupBy     String?
  isPublic    Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy User              @relation(fields: [createdById], references: [id])
  widgets   DashboardWidget[]

  @@index([objectType])
  @@index([createdById])
  @@index([deletedAt])
}

model Dashboard {
  id               String    @id @default(cuid())
  name             String
  description      String?
  visibility       String    @default("PRIVATE")
  defaultDateRange String?
  filters          Json?
  layout           Json?
  ownerId          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  widgets DashboardWidget[]
  owner   User?             @relation(fields: [ownerId], references: [id])

  @@index([visibility])
  @@index([ownerId])
  @@index([deletedAt])
}

model DashboardWidget {
  id          String   @id @default(cuid())
  dashboardId String
  reportId    String
  title       String
  widgetType  String
  config      Json     @default("{}")
  position    Json     @default("{}")
  size        String   @default("MEDIUM")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  report    Report    @relation(fields: [reportId], references: [id])

  @@index([dashboardId])
  @@index([reportId])
}

model SavedView {
  id         String   @id @default(cuid())
  objectType String
  name       String
  filters    Json     @default("{}")
  columns    Json     @default("[]")
  sortField  String?
  sortDir    String   @default("asc")
  isDefault  Boolean  @default(false)
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([objectType])
  @@index([userId])
}

model ImportJob {
  id           String    @id @default(cuid())
  objectType   String
  fileName     String
  status       String    @default("pending")
  totalRows    Int       @default(0)
  importedRows Int       @default(0)
  errorRows    Int       @default(0)
  errors       Json      @default("[]")
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  completedAt  DateTime?

  @@index([objectType])
  @@index([status])
  @@index([createdAt])
}

model ExportJob {
  id          String    @id @default(cuid())
  objectType  String
  filters     Json      @default("{}")
  status      String    @default("pending")
  fileName    String?
  rowCount    Int       @default(0)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  completedAt DateTime?

  @@index([objectType])
  @@index([createdAt])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  objectType String
  objectId   String
  action     String
  before     Json?
  after      Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([objectType, objectId])
  @@index([userId])
  @@index([createdAt])
  @@index([action])
}

model DataTag {
  id        String   @id @default(cuid())
  name      String   @unique
  color     String   @default("#0176d3")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  companies CompanyTag[]
  deals     DealTag[]
}

model CompanyTag {
  companyId String
  tagId     String
  createdAt DateTime @default(now())

  company Company @relation(fields: [companyId], references: [id], onDelete: Cascade)
  tag     DataTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([companyId, tagId])
}

model DealTag {
  dealId    String
  tagId     String
  createdAt DateTime @default(now())

  deal Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  tag  DataTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([dealId, tagId])
}

// ===================== Marketing Automation =====================

model Prospect {
  id              String    @id @default(cuid())
  email           String    @unique
  firstName       String?
  lastName        String?
  company         String?
  jobTitle        String?
  phone           String?
  website         String?
  industry        String?
  employeeSize    String?
  annualRevenue   Float?
  country         String?
  state           String?
  city            String?
  postalCode      String?
  source          String?   // web, import, manual, api
  score           Int       @default(0)
  grade           String    @default("D")
  status          String    @default("active") // active, paused, deleted, blacklisted
  doNotEmail      Boolean   @default(false)
  optedOut        Boolean   @default(false)
  optedOutAt      DateTime?
  emailBounced    Boolean   @default(false)
  emailBouncedAt  DateTime?
  spamComplaint   Boolean   @default(false)
  isConverted     Boolean   @default(false)
  convertedAt     DateTime?
  crmContactId    String?
  assignedUserId  String?
  lastActivityAt  DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  activities       ProspectActivity[]
  listMemberships  MarketingListMembership[]
  emailRecipients  EmailRecipient[]
  formSubmissions  FormSubmission[]
  visits           Visit[]
  programEnrollments ProgramEnrollment[]

  @@index([email])
  @@index([status])
  @@index([score])
  @@index([assignedUserId])
  @@index([deletedAt])
  @@index([createdAt])
}

model ProspectActivity {
  id          String   @id @default(cuid())
  prospectId  String
  type        String   // email_open, email_click, form_submit, page_view, email_send, score_change, status_change
  description String
  metadata    Json     @default("{}")
  score       Int      @default(0)
  createdAt   DateTime @default(now())

  prospect Prospect @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([prospectId])
  @@index([type])
  @@index([createdAt])
}

model Visitor {
  id          String    @id @default(cuid())
  visitorUid  String    @unique
  prospectId  String?
  ipAddress   String?
  userAgent   String?
  firstSeenAt DateTime  @default(now())
  lastSeenAt  DateTime  @default(now())
  pageViews   Int       @default(0)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  visits    Visit[]

  @@index([prospectId])
  @@index([visitorUid])
  @@index([lastSeenAt])
}

model Visit {
  id         String   @id @default(cuid())
  visitorId  String
  prospectId String?
  startedAt  DateTime @default(now())
  endedAt    DateTime?
  duration   Int?     // seconds
  pageCount  Int      @default(1)
  referrer   String?
  campaign   String?
  medium     String?
  source     String?
  createdAt  DateTime @default(now())

  visitor   Visitor   @relation(fields: [visitorId], references: [id], onDelete: Cascade)
  prospect  Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  pageViews PageView[]

  @@index([visitorId])
  @@index([prospectId])
  @@index([startedAt])
}

model PageView {
  id        String   @id @default(cuid())
  visitId   String
  url       String
  title     String?
  duration  Int?     // seconds
  viewedAt  DateTime @default(now())

  visit Visit @relation(fields: [visitId], references: [id], onDelete: Cascade)

  @@index([visitId])
  @@index([url])
  @@index([viewedAt])
}

model MarketingList {
  id          String    @id @default(cuid())
  name        String
  description String?
  type        String    @default("static") // static, dynamic
  rules       Json      @default("[]")
  isPublic    Boolean   @default(false)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  memberships MarketingListMembership[]
  emailSends  MarketingEmail[]

  @@index([type])
  @@index([deletedAt])
}

model MarketingListMembership {
  listId     String
  prospectId String
  addedAt    DateTime @default(now())
  addedBy    String?  // manual, automation, import

  list     MarketingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  prospect Prospect      @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@id([listId, prospectId])
  @@index([listId])
  @@index([prospectId])
}

model EmailTemplate {
  id          String    @id @default(cuid())
  name        String
  subject     String
  previewText String?
  bodyHtml    String
  bodyText    String?
  fromName    String?
  fromEmail   String?
  replyTo     String?
  type        String    @default("regular") // regular, drip, test
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  emails MarketingEmail[]

  @@index([type])
  @@index([deletedAt])
}

model MarketingEmail {
  id           String    @id @default(cuid())
  name         String
  subject      String
  templateId   String?
  listId       String?
  fromName     String
  fromEmail    String
  replyTo      String?
  bodyHtml     String
  bodyText     String?
  status       String    @default("draft") // draft, scheduled, sending, sent, paused
  scheduledAt  DateTime?
  sentAt       DateTime?
  totalSent    Int       @default(0)
  totalOpened  Int       @default(0)
  totalClicked Int       @default(0)
  totalBounced Int       @default(0)
  totalOptOut  Int       @default(0)
  createdById  String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  template   EmailTemplate?  @relation(fields: [templateId], references: [id])
  list       MarketingList?  @relation(fields: [listId], references: [id])
  recipients EmailRecipient[]

  @@index([status])
  @@index([scheduledAt])
  @@index([deletedAt])
}

model EmailRecipient {
  id         String    @id @default(cuid())
  emailId    String
  prospectId String
  status     String    @default("pending") // pending, sent, opened, clicked, bounced, opted_out
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  bouncedAt  DateTime?
  optedOutAt DateTime?
  metadata   Json      @default("{}")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  email    MarketingEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)
  prospect Prospect       @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([prospectId])
  @@index([status])
}

model MarketingForm {
  id          String    @id @default(cuid())
  name        String
  description String?
  fields      Json      @default("[]")
  style       Json      @default("{}")
  thankYouMsg String?
  redirectUrl String?
  isActive    Boolean   @default(true)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  submissions FormSubmission[]
  handlers    FormHandler[]

  @@index([isActive])
  @@index([deletedAt])
}

model FormSubmission {
  id          String   @id @default(cuid())
  formId      String
  prospectId  String?
  data        Json     @default("{}")
  ipAddress   String?
  userAgent   String?
  pageUrl     String?
  submittedAt DateTime @default(now())

  form     MarketingForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  prospect Prospect?     @relation(fields: [prospectId], references: [id], onDelete: SetNull)

  @@index([formId])
  @@index([prospectId])
  @@index([submittedAt])
}

model FormHandler {
  id          String    @id @default(cuid())
  formId      String
  name        String
  successUrl  String?
  errorUrl    String?
  isActive    Boolean   @default(true)
  kbaiEnabled Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  form MarketingForm @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@index([formId])
}

model LandingPage {
  id          String    @id @default(cuid())
  name        String
  title       String
  slug        String    @unique
  description String?
  bodyHtml    String    @default("")
  metaTitle   String?
  metaDesc    String?
  status      String    @default("draft") // draft, published, archived
  publishedAt DateTime?
  views       Int       @default(0)
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([status])
  @@index([slug])
  @@index([deletedAt])
}

model EngagementProgram {
  id          String    @id @default(cuid())
  name        String
  description String?
  status      String    @default("draft") // draft, active, paused, completed
  startDate   DateTime?
  endDate     DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  nodes       EngagementProgramNode[]
  enrollments ProgramEnrollment[]

  @@index([status])
  @@index([deletedAt])
}

model EngagementProgramNode {
  id          String  @id @default(cuid())
  programId   String
  type        String  // email, wait, condition, action
  label       String
  config      Json    @default("{}")
  positionX   Float   @default(0)
  positionY   Float   @default(0)
  nextNodeId  String?
  yesNodeId   String?
  noNodeId    String?

  program EngagementProgram @relation(fields: [programId], references: [id], onDelete: Cascade)

  @@index([programId])
}

model ProgramEnrollment {
  id          String    @id @default(cuid())
  programId   String
  prospectId  String
  status      String    @default("active") // active, paused, completed, removed
  currentNode String?
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  program  EngagementProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  prospect Prospect          @relation(fields: [prospectId], references: [id], onDelete: Cascade)

  @@unique([programId, prospectId])
  @@index([programId])
  @@index([prospectId])
  @@index([status])
}

model AutomationRule {
  id          String    @id @default(cuid())
  name        String
  description String?
  triggerType String    // prospect_created, form_submit, email_open, email_click, score_change, field_change, date_based
  triggerConf Json      @default("{}")
  conditions  Json      @default("[]")
  actions     Json      @default("[]")
  isActive    Boolean   @default(false)
  runCount    Int       @default(0)
  lastRunAt   DateTime?
  createdById String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  @@index([triggerType])
  @@index([isActive])
  @@index([deletedAt])
}

model ScoringRule {
  id          String    @id @default(cuid())
  name        String
  category    String    @default("behavior") // behavior, demographic
  triggerType String    // email_open, email_click, form_submit, page_view, etc.
  conditions  Json      @default("[]")
  scoreChange Int
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([category])
  @@index([isActive])
}

model GradingProfile {
  id          String   @id @default(cuid())
  name        String
  description String?
  criteria    Json     @default("[]")
  isDefault   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}
