generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===================== Auth & Settings =====================

model User {
  id                   String    @id @default(cuid())
  email                String    @unique
  name                 String?
  passwordHash         String
  role                 String    @default("SALES")
  status               String    @default("ACTIVE")
  profileId            String?
  department           String?
  title                String?
  phone                String?
  timezone             String    @default("Asia/Tokyo")
  locale               String    @default("ja")
  defaultAppId         String?
  forcePasswordChange  Boolean   @default(false)
  failedLoginAttempts  Int       @default(0)
  lockedUntil          DateTime?
  lastLoginAt          DateTime?
  passwordChangedAt    DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt
  deletedAt            DateTime?

  profile                  Profile?                  @relation(fields: [profileId], references: [id], onDelete: SetNull)
  auditLogs                AuditLog[]
  reports                  Report[]
  dashboards               Dashboard[]
  permissionSetAssignments PermissionSetAssignment[]
  appAccess                UserAppAccess[]
  teamMemberships          TeamMember[]
  loginHistory             LoginHistory[]
  sentInvitations          UserInvitation[]          @relation("InvitedBy")
  accountTeamMemberships   AccountTeamMember[]
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  parentId    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  parent   Role?  @relation("RoleHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children Role[] @relation("RoleHierarchy")

  @@index([parentId])
}

model Profile {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  isSystem    Boolean  @default(false)
  permissions Json     @default("{}")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  users User[]
}

model PermissionSet {
  id          String   @id @default(cuid())
  name        String   @unique
  label       String
  description String?
  permissions Json     @default("{}")
  isSystem    Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  assignments PermissionSetAssignment[]
}

model PermissionSetAssignment {
  id              String   @id @default(cuid())
  userId          String
  permissionSetId String
  assignedAt      DateTime @default(now())
  assignedById    String?

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionSet PermissionSet @relation(fields: [permissionSetId], references: [id], onDelete: Cascade)

  @@unique([userId, permissionSetId])
  @@index([userId])
  @@index([permissionSetId])
}

model Team {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  members TeamMember[]
}

model TeamMember {
  teamId   String
  userId   String
  role     String   @default("member")
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([teamId, userId])
  @@index([userId])
}

model UserAppAccess {
  userId    String
  appId     String
  grantedAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([userId, appId])
  @@index([userId])
}

model SecuritySettings {
  id                  String   @id @default("singleton")
  minPasswordLength   Int      @default(8)
  requireUppercase    Boolean  @default(true)
  requireNumbers      Boolean  @default(true)
  requireSymbols      Boolean  @default(false)
  passwordExpiryDays  Int      @default(0)
  maxLoginAttempts    Int      @default(5)
  lockoutDurationMins Int      @default(30)
  sessionTimeoutMins  Int      @default(480)
  mfaRequired         Boolean  @default(false)
  ipWhitelist         Json     @default("[]")
  updatedAt           DateTime @updatedAt
}

model OrgSettings {
  id          String   @id @default("singleton")
  orgName     String   @default("My Organization")
  orgTimezone String   @default("Asia/Tokyo")
  orgLocale   String   @default("ja")
  fiscalMonth Int      @default(4)
  dateFormat  String   @default("YYYY/MM/DD")
  currency    String   @default("JPY")
  updatedAt   DateTime @updatedAt
}

model UserInvitation {
  id          String    @id @default(cuid())
  email       String
  name        String?
  role        String    @default("SALES")
  profileId   String?
  token       String    @unique
  invitedById String?
  acceptedAt  DateTime?
  expiresAt   DateTime
  createdAt   DateTime  @default(now())

  invitedBy User? @relation("InvitedBy", fields: [invitedById], references: [id], onDelete: SetNull)

  @@index([token])
  @@index([email])
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  email     String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  createdAt DateTime  @default(now())

  @@index([token])
  @@index([email])
}

model LoginHistory {
  id        String   @id @default(cuid())
  userId    String
  ipAddress String?
  userAgent String?
  status    String   @default("success")
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([createdAt])
}

// ===================== CRM Core (Legacy —互換維持) =====================

model Company {
  id            String    @id @default(cuid())
  companyName   String
  website       String?
  industry      String?
  employeeSize  String?
  status        String    @default("prospect")
  type          String    @default("PROSPECT")
  ownerName     String?
  ownerId       String?
  phone         String?
  address       String?
  billingCountry    String?
  billingPrefecture String?
  billingCity       String?
  billingAddress    String?
  shippingCountry   String?
  shippingPrefecture String?
  shippingCity      String?
  shippingAddress   String?
  memo          String?
  annualRevenue Float?
  parentCompanyId   String?
  source        String?
  lastActivityAt    DateTime?
  nextTaskDueAt     DateTime?
  healthScore       Int?
  customFields      Json      @default("{}")
  legalName              String?
  displayName            String?
  domain                 String?
  mainEmail              String?
  subIndustry            String?
  capital                Float?
  foundedYear            Int?
  stockMarket            String?
  stockSymbol            String?
  corporateNumber        String?
  invoiceRegistrationNumber String?
  tier                   String?
  lifecycleStage         String?
  accountManagerId       String?
  customerSuccessManagerId String?
  businessSummary        String?
  painPoints             Json?
  objectives             Json?
  competitors            Json?
  technologies           Json?
  openPipelineAmount     Float     @default(0)
  wonAmount              Float     @default(0)
  activeContractValue    Float     @default(0)
  arr                    Float?
  mrr                    Float?
  renewalDate            DateTime?
  lastEngagementAt       DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  parentCompany Company?   @relation("CompanyHierarchy", fields: [parentCompanyId], references: [id], onDelete: SetNull)
  childCompanies Company[] @relation("CompanyHierarchy")
  contacts      Contact[]
  deals         Deal[]
  activities    Activity[]
  tasks         Task[]
  tags          CompanyTag[]
  leads         Lead[]
  cases         Case[]
  contracts     Contract[]
  orders        Order[]
  campaignMembers CampaignMember[]
  prospects     Prospect[]
  subscriptions Subscription[]
  accountTeamMembers  AccountTeamMember[]
  accountPlans        AccountPlan[]
  sourceRelationships AccountRelationship[] @relation("SourceAccount")
  targetRelationships AccountRelationship[] @relation("TargetAccount")
  accountStakeholders AccountStakeholder[]
  accountHealthSnapshots AccountHealthSnapshot[]
  accountInsights     AccountInsight[]

  @@index([status])
  @@index([deletedAt])
  @@index([companyName])
  @@index([ownerId])
  @@index([parentCompanyId])
  @@index([domain])
  @@index([tier])
  @@index([lastActivityAt])
}

model AccountTeamMember {
  id          String   @id @default(cuid())
  companyId   String
  userId      String
  role        String   @default("SALES_REP")
  isPrimary   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  user        User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([companyId, userId])
  @@index([companyId])
  @@index([userId])
}

model AccountPlan {
  id                     String   @id @default(cuid())
  companyId              String
  name                   String
  fiscalYear             String
  status                 String   @default("DRAFT")
  summary                String?
  businessObjectives     Json?
  keyInitiatives         Json?
  risks                  Json?
  expansionOpportunities Json?
  nextActions            Json?
  ownerId                String?
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt

  company                Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
}

model AccountRelationship {
  id               String   @id @default(cuid())
  sourceCompanyId  String
  targetCompanyId  String
  relationshipType String   @default("RELATED")
  description      String?
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  sourceCompany    Company  @relation("SourceAccount", fields: [sourceCompanyId], references: [id], onDelete: Cascade)
  targetCompany    Company  @relation("TargetAccount", fields: [targetCompanyId], references: [id], onDelete: Cascade)

  @@index([sourceCompanyId])
  @@index([targetCompanyId])
}

model AccountStakeholder {
  id             String   @id @default(cuid())
  companyId      String
  contactId      String
  influenceLevel String   @default("MEDIUM")
  attitude       String   @default("UNKNOWN")
  decisionRole   String   @default("OTHER")
  notes          String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  company        Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact        Contact  @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([companyId, contactId])
  @@index([companyId])
}

model AccountHealthSnapshot {
  id              String   @id @default(cuid())
  companyId       String
  healthScore     Int
  fitScore        Int?
  engagementScore Int?
  riskLevel       String   @default("LOW")
  reason          Json?
  measuredAt      DateTime @default(now())
  createdAt       DateTime @default(now())

  company         Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([measuredAt])
}

model AccountInsight {
  id          String   @id @default(cuid())
  companyId   String
  type        String   @default("CUSTOM")
  title       String
  body        String
  severity    String   @default("INFO")
  source      String   @default("SYSTEM")
  actionLabel String?
  actionUrl   String?
  isDismissed Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  company     Company  @relation(fields: [companyId], references: [id], onDelete: Cascade)

  @@index([companyId])
  @@index([isDismissed])
}

model RecordPageDefinition {
  id            String   @id @default(cuid())
  objectApiName String
  apiName       String
  label         String
  description   String?
  pageType      String   @default("RECORD_PAGE")
  template      String   @default("TABS_WITH_RIGHT_SIDEBAR")
  status        String   @default("DRAFT")
  layout        Json     @default("{}")
  version       Int      @default(1)
  isDefault     Boolean  @default(false)
  createdById   String?
  updatedById   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  deletedAt     DateTime?

  components    PageComponentInstance[]
  assignments   RecordPageAssignment[]
  pageVersions  RecordPageVersion[]

  @@unique([objectApiName, apiName])
  @@index([objectApiName])
  @@index([status])
}

model RecordPageVersion {
  id            String   @id @default(cuid())
  recordPageId  String
  version       Int
  layout        Json
  publishedById String?
  publishedAt   DateTime?
  createdAt     DateTime @default(now())

  recordPage    RecordPageDefinition @relation(fields: [recordPageId], references: [id], onDelete: Cascade)

  @@index([recordPageId])
}

model RecordPageAssignment {
  id            String   @id @default(cuid())
  recordPageId  String
  objectApiName String
  appId         String?
  recordTypeId  String?
  profileId     String?
  formFactor    String   @default("BOTH")
  priority      Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  recordPage    RecordPageDefinition @relation(fields: [recordPageId], references: [id], onDelete: Cascade)

  @@index([objectApiName])
  @@index([recordPageId])
}

model PageComponentInstance {
  id              String   @id @default(cuid())
  recordPageId    String
  componentType   String
  region          String   @default("main")
  sortOrder       Int      @default(0)
  config          Json     @default("{}")
  visibilityRules Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  recordPage      RecordPageDefinition @relation(fields: [recordPageId], references: [id], onDelete: Cascade)

  @@index([recordPageId])
  @@index([region])
}

model Contact {
  id           String    @id @default(cuid())
  companyId    String
  firstName    String?
  lastName     String?
  fullName     String
  email        String?
  phone        String?
  mobilePhone  String?
  department   String?
  title        String?
  roleInDecision String?
  isPrimary    Boolean   @default(false)
  leadSource   String?
  ownerId      String?
  crmLifecycleStage String?
  lastActivityAt DateTime?
  prospectId   String?   @unique
  memo         String?
  customFields Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company              Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  prospect             Prospect?                @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  deals                Deal[]
  activities           Activity[]
  opportunityRoles     OpportunityContactRole[]
  campaignMembers      CampaignMember[]
  cases                Case[]
  activityRelations    ActivityRelation[]
  accountStakeholders  AccountStakeholder[]

  @@index([companyId])
  @@index([email])
  @@index([deletedAt])
  @@index([ownerId])
  @@index([prospectId])
}

model Deal {
  id                String    @id @default(cuid())
  companyId         String
  contactId         String?
  dealName          String
  stage             String    @default("lead")
  forecastCategory  String    @default("PIPELINE")
  type              String    @default("NEW_BUSINESS")
  leadSource        String?
  amount            Float     @default(0)
  probability       Int       @default(0)
  expectedCloseDate DateTime?
  closeDate         DateTime?
  nextAction        String?
  nextStep          String?
  memo              String?
  lostReason        String?
  ownerId           String?
  primaryContactId  String?
  campaignId        String?
  customFields      Json      @default("{}")
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt
  deletedAt         DateTime?

  company              Company                  @relation(fields: [companyId], references: [id], onDelete: Cascade)
  contact              Contact?                 @relation(fields: [contactId], references: [id], onDelete: SetNull)
  campaign             Campaign?                @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  activities           Activity[]
  tasks                Task[]
  tags                 DealTag[]
  contactRoles         OpportunityContactRole[]
  stageHistory         OpportunityStageHistory[]
  lineItems            OpportunityLineItem[]
  quotes               Quote[]
  contracts            Contract[]
  orders               Order[]
  campaignInfluences   CampaignInfluence[]
  activityRelations    ActivityRelation[]

  @@index([companyId])
  @@index([stage])
  @@index([expectedCloseDate])
  @@index([deletedAt])
  @@index([ownerId])
  @@index([campaignId])
}

model Activity {
  id           String   @id @default(cuid())
  companyId    String?
  contactId    String?
  dealId       String?
  leadId       String?
  caseId       String?
  createdById  String?
  type         String   @default("note")
  subject      String
  body         String?
  activityDate DateTime @default(now())
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  company  Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact  Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal     Deal?     @relation(fields: [dealId], references: [id], onDelete: SetNull)
  lead     Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  case     Case?     @relation(fields: [caseId], references: [id], onDelete: SetNull)
  relations ActivityRelation[]

  @@index([companyId])
  @@index([dealId])
  @@index([leadId])
  @@index([caseId])
  @@index([activityDate])
}

model ActivityRelation {
  id           String   @id @default(cuid())
  activityId   String
  objectType   String
  objectId     String
  relationType String   @default("RELATED")
  contactId    String?
  dealId       String?
  createdAt    DateTime @default(now())

  leadId       String?

  activity Activity @relation(fields: [activityId], references: [id], onDelete: Cascade)
  contact  Contact? @relation(fields: [contactId], references: [id], onDelete: SetNull)
  deal     Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  lead     Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([activityId])
  @@index([objectType, objectId])
}

model Task {
  id          String    @id @default(cuid())
  companyId   String?
  dealId      String?
  leadId      String?
  caseId      String?
  assigneeId  String?
  title       String
  description String?
  dueDate     DateTime?
  priority    String    @default("medium")
  status      String    @default("todo")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  company Company? @relation(fields: [companyId], references: [id], onDelete: SetNull)
  deal    Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  lead    Lead?    @relation(fields: [leadId], references: [id], onDelete: SetNull)
  case    Case?    @relation(fields: [caseId], references: [id], onDelete: SetNull)

  @@index([status])
  @@index([dueDate])
  @@index([dealId])
  @@index([leadId])
  @@index([assigneeId])
}

// ===================== CRM Standard Objects (New) =====================

model Lead {
  id                    String    @id @default(cuid())
  firstName             String?
  lastName              String?
  fullName              String
  email                 String?
  phone                 String?
  mobilePhone           String?
  companyName           String?
  title                 String?
  department            String?
  industry              String?
  website               String?
  country               String?
  prefecture            String?
  city                  String?
  source                String?
  leadSource            String?
  status                String    @default("NEW")
  lifecycleStage        String?
  rating                String    @default("COLD")
  score                 Int?      @default(0)
  grade                 String?   @default("D")
  doNotEmail            Boolean   @default(false)
  optedOut              Boolean   @default(false)
  optedOutAt            DateTime?
  emailBounced          Boolean   @default(false)
  emailBouncedAt        DateTime?
  spamComplaint         Boolean   @default(false)
  consentStatus         String    @default("UNKNOWN")
  consentUpdatedAt      DateTime?
  ownerId               String?
  assignedUserId        String?
  companyId             String?
  crmContactId          String?
  crmAccountId          String?
  prospectId            String?   @unique
  convertedAccountId    String?
  convertedContactId    String?
  convertedDealId       String?
  convertedAt           DateTime?
  disqualifiedReason    String?
  lastActivityAt        DateTime?
  customFields          Json      @default("{}")
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  deletedAt             DateTime?

  company              Company?              @relation(fields: [companyId], references: [id], onDelete: SetNull)
  prospect             Prospect?             @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  activities           Activity[]
  tasks                Task[]
  campaignMembers      CampaignMember[]
  activityRelations    ActivityRelation[]
  engagementActivities LeadEngagementActivity[]
  listMemberships      LeadListMembership[]
  emailRecipients      LeadEmailRecipient[]
  formSubmissions      LeadFormSubmission[]
  programEnrollments   LeadProgramEnrollment[]

  @@index([email])
  @@index([status])
  @@index([lifecycleStage])
  @@index([score])
  @@index([grade])
  @@index([ownerId])
  @@index([assignedUserId])
  @@index([companyId])
  @@index([crmContactId])
  @@index([prospectId])
  @@index([lastActivityAt])
  @@index([convertedAt])
  @@index([deletedAt])
}

// Lead-centric MA activity (replaces ProspectActivity for new records)
model LeadEngagementActivity {
  id         String   @id @default(cuid())
  leadId     String
  type       String
  description String
  metadata   Json     @default("{}")
  score      Int      @default(0)
  createdAt  DateTime @default(now())

  lead Lead @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([leadId])
  @@index([type])
  @@index([createdAt])
}

// Lead-centric list membership (replaces MarketingListMembership for new records)
model LeadListMembership {
  listId    String
  leadId    String
  addedAt   DateTime @default(now())
  addedBy   String?

  list MarketingList @relation(fields: [listId], references: [id], onDelete: Cascade)
  lead Lead          @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@id([listId, leadId])
  @@index([listId])
  @@index([leadId])
}

// Lead-centric email recipient (replaces EmailRecipient for new records)
model LeadEmailRecipient {
  id         String    @id @default(cuid())
  emailId    String
  leadId     String
  status     String    @default("pending")
  sentAt     DateTime?
  openedAt   DateTime?
  clickedAt  DateTime?
  bouncedAt  DateTime?
  optedOutAt DateTime?
  metadata   Json      @default("{}")
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  email MarketingEmail @relation(fields: [emailId], references: [id], onDelete: Cascade)
  lead  Lead           @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@index([emailId])
  @@index([leadId])
  @@index([status])
}

// Lead-centric form submission (replaces FormSubmission for new records)
model LeadFormSubmission {
  id          String   @id @default(cuid())
  formId      String
  leadId      String?
  data        Json     @default("{}")
  ipAddress   String?
  userAgent   String?
  pageUrl     String?
  submittedAt DateTime @default(now())

  form MarketingForm @relation(fields: [formId], references: [id], onDelete: Cascade)
  lead Lead?         @relation(fields: [leadId], references: [id], onDelete: SetNull)

  @@index([formId])
  @@index([leadId])
  @@index([submittedAt])
}

// Lead-centric program enrollment (replaces ProgramEnrollment for new records)
model LeadProgramEnrollment {
  id          String    @id @default(cuid())
  programId   String
  leadId      String
  status      String    @default("active")
  currentNode String?
  enrolledAt  DateTime  @default(now())
  completedAt DateTime?
  updatedAt   DateTime  @updatedAt

  program EngagementProgram @relation(fields: [programId], references: [id], onDelete: Cascade)
  lead    Lead              @relation(fields: [leadId], references: [id], onDelete: Cascade)

  @@unique([programId, leadId])
  @@index([programId])
  @@index([leadId])
  @@index([status])
}

model OpportunityContactRole {
  id            String   @id @default(cuid())
  dealId        String
  contactId     String
  role          String   @default("OTHER")
  isPrimary     Boolean  @default(false)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  deal    Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)
  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@unique([dealId, contactId])
  @@index([dealId])
  @@index([contactId])
}

model OpportunityStageHistory {
  id              String   @id @default(cuid())
  dealId          String
  oldStage        String?
  newStage        String
  oldAmount       Float?
  newAmount       Float?
  oldProbability  Int?
  newProbability  Int?
  changedById     String?
  changedAt       DateTime @default(now())

  deal Deal @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@index([dealId])
  @@index([changedAt])
}

model Campaign {
  id              String    @id @default(cuid())
  name            String
  type            String    @default("OTHER")
  status          String    @default("PLANNED")
  startDate       DateTime?
  endDate         DateTime?
  budget          Float?
  actualCost      Float?
  expectedRevenue Float?
  ownerId         String?
  parentCampaignId String?
  description     String?
  isActive        Boolean   @default(true)
  customFields    Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  parentCampaign  Campaign?          @relation("CampaignHierarchy", fields: [parentCampaignId], references: [id], onDelete: SetNull)
  childCampaigns  Campaign[]         @relation("CampaignHierarchy")
  members         CampaignMember[]
  influences      CampaignInfluence[]
  deals           Deal[]
  marketingEmails MarketingEmail[]
  marketingForms  MarketingForm[]
  landingPages    LandingPage[]
  engagementPrograms EngagementProgram[]

  @@index([status])
  @@index([ownerId])
  @@index([parentCampaignId])
  @@index([deletedAt])
}

model CampaignMember {
  id               String    @id @default(cuid())
  campaignId       String
  leadId           String?
  contactId        String?
  prospectId       String?
  companyId        String?
  status           String    @default("SENT")
  responded        Boolean   @default(false)
  firstRespondedAt DateTime?
  score            Int?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  campaign  Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  lead      Lead?     @relation(fields: [leadId], references: [id], onDelete: SetNull)
  contact   Contact?  @relation(fields: [contactId], references: [id], onDelete: SetNull)
  prospect  Prospect? @relation(fields: [prospectId], references: [id], onDelete: SetNull)
  company   Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)

  @@index([campaignId])
  @@index([leadId])
  @@index([contactId])
  @@index([prospectId])
}

model CampaignInfluence {
  id             String   @id @default(cuid())
  campaignId     String
  dealId         String
  contactId      String?
  influenceType  String   @default("MULTI_TOUCH")
  revenueShare   Float    @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  campaign Campaign @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  deal     Deal     @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([campaignId, dealId])
  @@index([campaignId])
  @@index([dealId])
}

model Product {
  id           String    @id @default(cuid())
  name         String
  productCode  String?   @unique
  description  String?
  family       String?
  isActive     Boolean   @default(true)
  customFields Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  priceBookEntries  PriceBookEntry[]
  lineItems         OpportunityLineItem[]
  quoteLineItems    QuoteLineItem[]
  orderItems        OrderItem[]
  subscriptions     Subscription[]

  @@index([isActive])
  @@index([deletedAt])
}

model PriceBook {
  id          String    @id @default(cuid())
  name        String
  description String?
  isStandard  Boolean   @default(false)
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  entries PriceBookEntry[]

  @@index([isActive])
}

model PriceBookEntry {
  id          String    @id @default(cuid())
  priceBookId String
  productId   String
  unitPrice   Float
  currency    String    @default("JPY")
  isActive    Boolean   @default(true)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  priceBook  PriceBook            @relation(fields: [priceBookId], references: [id], onDelete: Cascade)
  product    Product              @relation(fields: [productId], references: [id], onDelete: Cascade)
  lineItems  OpportunityLineItem[]

  @@unique([priceBookId, productId])
  @@index([priceBookId])
  @@index([productId])
}

model OpportunityLineItem {
  id                String   @id @default(cuid())
  dealId            String
  priceBookEntryId  String?
  productId         String
  quantity          Float    @default(1)
  unitPrice         Float
  discountPercent   Float    @default(0)
  totalPrice        Float
  description       String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  deal           Deal            @relation(fields: [dealId], references: [id], onDelete: Cascade)
  priceBookEntry PriceBookEntry? @relation(fields: [priceBookEntryId], references: [id], onDelete: SetNull)
  product        Product         @relation(fields: [productId], references: [id], onDelete: Restrict)

  @@index([dealId])
  @@index([productId])
}

model Quote {
  id            String    @id @default(cuid())
  dealId        String
  companyId     String?
  name          String
  quoteNumber   String    @unique
  status        String    @default("DRAFT")
  validUntil    DateTime?
  subtotal      Float     @default(0)
  discountTotal Float     @default(0)
  taxTotal      Float     @default(0)
  grandTotal    Float     @default(0)
  ownerId       String?
  notes         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  deletedAt     DateTime?

  deal      Deal          @relation(fields: [dealId], references: [id], onDelete: Cascade)
  lineItems QuoteLineItem[]
  contracts Contract[]
  orders    Order[]

  @@index([dealId])
  @@index([status])
  @@index([deletedAt])
}

model QuoteLineItem {
  id              String   @id @default(cuid())
  quoteId         String
  productId       String?
  description     String?
  quantity        Float    @default(1)
  unitPrice       Float
  discountPercent Float    @default(0)
  totalPrice      Float
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  quote   Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([quoteId])
}

model Contract {
  id              String    @id @default(cuid())
  companyId       String
  dealId          String?
  quoteId         String?
  name            String
  contractNumber  String    @unique
  status          String    @default("DRAFT")
  startDate       DateTime
  endDate         DateTime?
  contractValue   Float     @default(0)
  ownerId         String?
  customFields    Json      @default("{}")
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt
  deletedAt       DateTime?

  company       Company  @relation(fields: [companyId], references: [id], onDelete: Restrict)
  deal          Deal?    @relation(fields: [dealId], references: [id], onDelete: SetNull)
  quote         Quote?   @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  orders        Order[]
  subscriptions Subscription[]

  @@index([companyId])
  @@index([dealId])
  @@index([status])
  @@index([deletedAt])
}

model Order {
  id          String    @id @default(cuid())
  companyId   String
  dealId      String?
  quoteId     String?
  contractId  String?
  orderNumber String    @unique
  status      String    @default("DRAFT")
  orderDate   DateTime  @default(now())
  totalAmount Float     @default(0)
  ownerId     String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  company  Company    @relation(fields: [companyId], references: [id], onDelete: Restrict)
  deal     Deal?      @relation(fields: [dealId], references: [id], onDelete: SetNull)
  quote    Quote?     @relation(fields: [quoteId], references: [id], onDelete: SetNull)
  contract Contract?  @relation(fields: [contractId], references: [id], onDelete: SetNull)
  items    OrderItem[]

  @@index([companyId])
  @@index([status])
  @@index([deletedAt])
}

model OrderItem {
  id         String   @id @default(cuid())
  orderId    String
  productId  String?
  quantity   Float    @default(1)
  unitPrice  Float
  totalPrice Float
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  order   Order    @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product? @relation(fields: [productId], references: [id], onDelete: SetNull)

  @@index([orderId])
}

model Case {
  id           String    @id @default(cuid())
  caseNumber   String    @unique @default(cuid())
  companyId    String?
  contactId    String?
  subject      String
  description  String?
  status       String    @default("New")
  priority     String    @default("Medium")
  origin       String?
  type         String?
  ownerId      String?
  closedAt     DateTime?
  resolvedAt   DateTime?
  resolution   String?
  customFields Json      @default("{}")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  deletedAt    DateTime?

  company    Company?   @relation(fields: [companyId], references: [id], onDelete: SetNull)
  contact    Contact?   @relation(fields: [contactId], references: [id], onDelete: SetNull)
  activities Activity[]
  tasks      Task[]

  @@index([companyId])
  @@index([contactId])
  @@index([status])
  @@index([priority])
  @@index([deletedAt])
}

// ===================== Analytics =====================

model Report {
  id          String    @id @default(cuid())
  name        String
  description String?
  objectType  String
  columns     Json
  filters     Json      @default("[]")
  sortField   String?
  sortDir     String    @default("desc")
  groupBy     String?
  isPublic    Boolean   @default(false)
  createdById String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  deletedAt   DateTime?

  createdBy User              @relation(fields: [createdById], references: [id])
  widgets   DashboardWidget[]

  @@index([objectType])
  @@index([createdById])
  @@index([deletedAt])
}

model Dashboard {
  id               String    @id @default(cuid())
  name             String
  description      String?
  visibility       String    @default("PRIVATE")
  defaultDateRange String?
  filters          Json?
  layout           Json?
  ownerId          String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  deletedAt        DateTime?

  widgets DashboardWidget[]
  owner   User?             @relation(fields: [ownerId], references: [id])

  @@index([visibility])
  @@index([ownerId])
  @@index([deletedAt])
}

model DashboardWidget {
  id          String   @id @default(cuid())
  dashboardId String
  reportId    String
  title       String
  widgetType  String
  config      Json     @default("{}")
  position    Json     @default("{}")
  size        String   @default("MEDIUM")
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  dashboard Dashboard @relation(fields: [dashboardId], references: [id], onDelete: Cascade)
  report    Report    @relation(fields: [reportId], references: [id])

  @@index([dashboardId])
  @@index([reportId])
}

model SavedView {
  id         String   @id @default(cuid())
  objectType String
  name       String
  filters    Json     @default("{}")
  columns    Json     @default("[]")
  sortField  String?
  sortDir    String   @default("asc")
  isDefault  Boolean  @default(false)
  userId     String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([objectType])
  @@index([userId])
}

